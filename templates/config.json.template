{
  "version": "0.1.0",
  "models": {
    "codex": "gpt-5.4",
    "gemini": "gemini-3.1-pro-preview",
    "claude_intent": "sonnet"
  },
  "intent_inference": {
    "enabled": true,
    "max_intents": 3,
    "authority": "claude",
    "higher_order_purpose_required": true,
    "unknown_intent_default_category": "implementation",
    "confirm_on_ambiguity": false
  },
  "quota_sources": {
    "claude": {
      "mode": "hybrid",
      "live_enabled": true,
      "live_state_file": "~/.claude/plugins/data/cch-claudin-codex-heavy/live-quota-state.json",
      "state_file": "~/.claude/plugins/data/cch-claudin-codex-heavy/quota-state.json"
    },
    "gemini": {
      "mode": "hybrid",
      "live_enabled": true,
      "live_state_file": "~/.claude/plugins/data/cch-claudin-codex-heavy/live-quota-state.json",
      "state_file": "~/.claude/plugins/data/cch-claudin-codex-heavy/quota-state.json"
    }
  },
  "thresholds": {
    "claude": {
      "hourly_warn": 60,
      "weekly_warn": 80,
      "hourly_exhausted": 95,
      "weekly_exhausted": 95
    },
    "gemini": {
      "hourly_warn": 60,
      "weekly_warn": 80,
      "hourly_exhausted": 95,
      "weekly_exhausted": 95
    }
  },
  "quota_state_file": "~/.claude/plugins/data/cch-claudin-codex-heavy/quota-state.json",
  "default_category": "implementation",
  "categories": {
    "implementation": {
      "leader": "claude",
      "executor": "codex:gpt-5.4",
      "fallback": "codex:gpt-5.4",
      "quota_bias": "codex-first"
    },
    "research": {
      "leader": "gemini",
      "executor": "gemini:default",
      "fallback": "codex:gpt-5.4",
      "quota_bias": "gemini-first"
    },
    "verification": {
      "leader": "claude",
      "executor": "codex:gpt-5.4",
      "fallback": "codex:gpt-5.4",
      "quota_bias": "codex-first"
    },
    "security": {
      "leader": "claude",
      "executor": "codex:gpt-5.4",
      "fallback": "gemini:default",
      "quota_bias": "codex-first"
    },
    "debate": {
      "leader": "claude",
      "executor": "codex+gemini",
      "fallback": "codex:gpt-5.4",
      "quota_bias": "balanced"
    },
    "documentation": {
      "leader": "claude",
      "executor": "claude",
      "fallback": "codex:gpt-5.4",
      "quota_bias": "claude-first"
    },
    "planning": {
      "leader": "claude",
      "executor": "claude",
      "fallback": "codex:gpt-5.4",
      "quota_bias": "claude-first"
    }
  },
  "modes": {
    "normal": {
      "providers": ["codex", "gemini", "claude"]
    },
    "codex-heavy": {
      "providers": ["codex", "gemini", "claude"],
      "codex_bias": true
    },
    "codex-only": {
      "providers": ["codex"]
    }
  }
}
